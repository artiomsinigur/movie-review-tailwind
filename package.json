{
    "name": "movie-review-tailwind",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": ">=24.13.0",
        "yarn": ">=3.0.0"
    },
    "volta": {
        "node": "24.13.0",
        "yarn": "3.8.7"
    },
    "workspaces": [
        "backend",
        "frontend"
    ],
    "scripts": {
        "dev": "yarn workspace frontend dev",
        "build": "yarn workspace frontend build",
        "lint": "yarn workspaces foreach -A run lint",
        "preview": "yarn workspace frontend preview",
        "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
        "server": "node backend/server.js"
    },
    "dependencies": {
        "express": "^5.2.1",
        "sqlite3": "^6.0.1"
    },
    "devDependencies": {
        "@types/node": "^24.12.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2"
    }
}
