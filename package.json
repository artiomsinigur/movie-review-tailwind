{
    "name": "movie-review-tailwind",
    "private": true,
    "version": "1.0.0",
    "license": "MIT",
    "author": "Artiom",
    "type": "module",
    "engines": {
        "node": ">=24.13.0",
        "yarn": ">=4.0.0"
    },
    "workspaces": [
        "backend",
        "frontend",
        "foundry"
    ],
    "scripts": {
        "clean": "yarn workspaces foreach -A run clean",
        "dev": "yarn workspaces foreach -Api run dev",
        "build": "yarn workspaces foreach -A run build",
        "lint": "yarn workspaces foreach -A run lint",
        "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\""
    },
    "devDependencies": {
        "@types/node": "^24.12.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "catalog:default"
    },
    "packageManager": "yarn@4.13.0",
    "volta": {
        "node": "24.13.0",
        "yarn": "4.13.0"
    }
}
